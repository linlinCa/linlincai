---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
---
<BaseLayout lang="en" title="Linlincai | Product Manager & AI Explorer" currentPath={Astro.url.pathname}>
  <section class="hero">
    <div class="container hero-layout">
      <div class="hero-text">
        <div class="eyebrow">Product Manager & AI Explorer</div>
        <h1>A generalist at heart.</h1>
        <p>
          Not defined by a single role. I explore the relationship between AI and people across research,
          product, and expression.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={withBase('/en/projects/')}>View Projects</a>
          <a class="button secondary" href={withBase('/en/about/')}>About Me</a>
        </div>
      </div>
      <div class="hero-portrait">
        <img class="hero-photo" src={withBase('/images/profile.jpg')} alt="Portrait of Linlincai" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <p class="section-kicker">About</p>
        <h2 class="section-title">An open-ended explorer.</h2>
      </div>
      <div class="prose">
        <p>
          In a time of rapid technological change, I hope to explore what makes us uniquely human
          through products, reading, and continuous practice.
        </p>
        <p>
          I care about which problems are truly worth solving with AI, and whether product experiences
          make people feel understood and respected.
        </p>
        <p>
          I do not set limits or labels for myself. I stay curious and keep exploring what I truly care about.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        kicker="Selected Projects"
        title="A few things I’ve built and explored"
        description="Exploring across fields without setting limits."
        linkText="All Projects"
        linkHref={withBase('/en/projects/')}
      />
      <div class="project-grid">
        {projects.map((project) => <ProjectCard project={project} lang="en" />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        kicker="Thinking"
        title="Notes on AI, product, and growth"
        description="A place for essays and notes. For now, this section can start small and grow with your writing."
        linkText="Read Notes"
        linkHref={withBase('/en/thinking/')}
      />
      <div class="note-list">
        <a class="card note-item" href={withBase('/en/thinking/ai-native-pm/')}>
          <h3>In the AI era, PMs win by understanding users, value, and boundaries.</h3>
          <p>A framework from Prof. Rubingsheng Ru: four stages for AI-native PMs, moving from tools to capability, systems, and value judgment.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
