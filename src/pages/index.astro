---
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${withBase('/en/')}`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>
      Redirecting to <a href={withBase('/en/')}>English version</a>...
    </p>
  </body>
</html>
