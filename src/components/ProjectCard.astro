---
import type { Project, Lang } from '../data/projects';
const { project, lang = 'en' } = Astro.props as { project: Project; lang?: Lang };
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
const href = withBase(`/${lang}/projects/${project.slug}/`);
---
<a class="card project-card" href={href}>
  <div class="project-cover">
    <img src={withBase(project.cover)} alt={project.title[lang]} loading="lazy" />
  </div>
  <div class="project-card-body">
    <div class="meta">{project.year} · {project.category[lang]}</div>
    <h3>{project.title[lang]}</h3>
    <p>{project.subtitle[lang]}</p>
    <div class="tags">
      {project.tags[lang].slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
</a>
